{
  "entities": {
    "User": {
      "title": "User",
      "description": "Registered partner or student account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user" },
        "name": { "type": "string", "description": "The user's real full name" },
        "email": { "type": "string", "description": "The user's email address" },
        "phone": { "type": "string", "description": "The user's mobile or WhatsApp helpline" },
        "course": { "type": "string", "description": "Course selected for enrollment" },
        "payoutUpi": { "type": "string", "description": "UPI ID for commission cash-outs" },
        "promoCode": { "type": "string", "description": "Unique partner referral coupon code" },
        "partnerLevel": { "type": "string", "enum": ["novice", "pro", "master"], "description": "Partner tier of the user" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Inception timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last modified timestamp" }
      },
      "required": ["uid", "name", "email", "createdAt"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Contact form submissions and inquiries",
      "type": "object",
      "properties": {
        "userName": { "type": "string", "description": "Individual full name" },
        "userEmail": { "type": "string", "description": "Contact inbox address" },
        "userSubject": { "type": "string", "description": "Inquiry subject line" },
        "userMessage": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["userName", "userEmail", "userSubject", "userMessage", "createdAt"]
    },
    "Referral": {
      "title": "Referral",
      "description": "Referral leads tracked for a partner",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Internal referral tracking ID" },
        "name": { "type": "string", "description": "Prospect lead name" },
        "courseSelected": { "type": "string", "description": "Course selected" },
        "coursePrice": { "type": "number", "description": "Cost of course" },
        "commissionEarned": { "type": "number", "description": "Commissions created" },
        "status": { "type": "string", "enum": ["Completed", "Pending", "Lead Only"], "description": "Assigned status" },
        "referrerUid": { "type": "string", "description": "Referrer UID" },
        "date": { "type": "string", "description": "Calendar date string of entry" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["id", "name", "courseSelected", "coursePrice", "commissionEarned", "status", "referrerUid", "date", "createdAt"]
    },
    "UserPayment": {
      "title": "UserPayment",
      "description": "Payment and course enrollment receipts for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Transaction identification string" },
        "courseOrPlanName": { "type": "string", "description": "Name of the practical course or plan" },
        "amount": { "type": "number", "description": "Numeric pricing value paid" },
        "paymentMethod": { "type": "string", "enum": ["upi", "card"], "description": "Payment method choice" },
        "transactionId": { "type": "string", "description": "Debit reference or UTR reference string" },
        "status": { "type": "string", "enum": ["Completed", "Pending", "Verification Pending"], "description": "Transactional validation status" },
        "date": { "type": "string", "description": "Calendar date of entry" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Registration timestamp" }
      },
      "required": ["id", "courseOrPlanName", "amount", "paymentMethod", "transactionId", "status", "date"]
    },
    "WorkshopRegistration": {
      "title": "WorkshopRegistration",
      "description": "Registration for a free digital marketing workshop",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Registration ID" },
        "userId": { "type": "string", "description": "User UID if authenticated" },
        "name": { "type": "string", "description": "Attendee full name" },
        "email": { "type": "string", "description": "Attendee email address" },
        "phone": { "type": "string", "description": "Attendee phone number" },
        "workshopDate": { "type": "string", "description": "Calendar date of workshop" },
        "workshopTitle": { "type": "string", "description": "Title of the workshop" },
        "registeredAt": { "type": "string", "description": "Timestamp of registration" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Firestore server registration timestamp" }
      },
      "required": ["id", "name", "email", "workshopDate", "workshopTitle", "registeredAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile details keyed by auth UID"
    },
    "inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "A contact inquiry ticket saved from the website"
    },
    "users/{userId}/referrals/{referralId}": {
      "schema": "Referral",
      "description": "Sub-collection tracking a partner's referred leads"
    },
    "users/{userId}/payments/{paymentId}": {
      "schema": "UserPayment",
      "description": "Sub-collection tracking course enrollments/payments"
    },
    "users/{userId}/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Sub-collection tracking individual user inquiries"
    },
    "users/{userId}/workshops/{workshopId}": {
      "schema": "WorkshopRegistration",
      "description": "Sub-collection tracking workshop registrations"
    }
  }
}
